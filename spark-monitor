# Check dependencies
cmd_deps() {
    local skip_install=false
    local check_only=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --skip-install)
                skip_install=true
                shift
                ;;
            --check-only)
                check_only=true
                shift
                ;;
            *)
                print_error "Unknown option: $1"
                return 1
                ;;
        esac
    done
    
    print_header
    echo "Dependency Check"
    echo "----------------"
    
    local missing=()
    local found=()
    
    # Check Docker
    if command -v docker &> /dev/null; then
        found+=("Docker")
    else
        missing+=("Docker")
    fi
    
    # Check Docker Compose
    if command -v docker compose &> /dev/null; then
        found+=("Docker Compose")
    else
        missing+=("Docker Compose")
    fi
    
    # Check curl
    if command -v curl &> /dev/null; then
        found+=("curl")
    else
        missing+=("curl")
    fi
    
    # Check jq
    if command -v jq &> /dev/null; then
        found+=("jq")
    else
        missing+=("jq")
    fi
    
    echo ""
    echo "Installed:"
    if [ ${#found[@]} -gt 0 ]; then
        for dep in "${found[@]}"; do
            echo "  ✓ $dep"
        done
    else
        echo "  (none)"
    fi
    
    echo ""
    echo "Missing:"
    if [ ${#missing[@]} -gt 0 ]; then
        for dep in "${missing[@]}"; do
            echo "  ✗ $dep"
        done
        
        if [[ "$skip_install" != "true" ]] && [[ "$check_only" != "true" ]]; then
            echo ""
            echo "Attempting to install missing dependencies..."
            for dep in "${missing[@]}"; do
                if [[ "$dep" == "Docker" ]]; then
                    echo "  Installing Docker..."
                    if command -v apt-get &> /dev/null; then
                        sudo apt-get update && sudo apt-get install -y docker.io docker-compose
                    elif command -v dnf &> /dev/null; then
                        sudo dnf install -y docker docker-compose
                    elif command -v yum &> /dev/null; then
                        sudo yum install -y docker docker-compose
                    elif [[ "$OSTYPE" == "darwin"* ]]; then
                        echo "  Please install Docker Desktop for macOS"
                    else
                        echo "  Please install Docker manually"
                    fi
                elif [[ "$dep" == "Docker Compose" ]]; then
                    echo "  Installing Docker Compose..."
                    if command -v apt-get &> /dev/null; then
                        sudo apt-get install -y docker-compose
                    elif command -v dnf &> /dev/null; then
                        sudo dnf install -y docker-compose
                    elif command -v yum &> /dev/null; then
                        sudo yum install -y docker-compose
                    elif [[ "$OSTYPE" == "darwin"* ]]; then
                        echo "  Docker Compose is included in Docker Desktop"
                    else
                        echo "  Please install Docker Compose manually"
                    fi
                elif [[ "$dep" == "curl" ]]; then
                    echo "  Installing curl..."
                    if command -v apt-get &> /dev/null; then
                        sudo apt-get install -y curl
                    elif command -v dnf &> /dev/null; then
                        sudo dnf install -y curl
                    elif command -v yum &> /dev/null; then
                        sudo yum install -y curl
                    else
                        echo "  Please install curl manually"
                    fi
                elif [[ "$dep" == "jq" ]]; then
                    echo "  Installing jq..."
                    if command -v apt-get &> /dev/null; then
                        sudo apt-get install -y jq
                    elif command -v dnf &> /dev/null; then
                        sudo dnf install -y jq
                    elif command -v yum &> /dev/null; then
                        sudo yum install -y jq
                    else
                        echo "  Please install jq manually"
                    fi
                fi
            done
            print_success "Installation attempts complete"
        fi
    else
        echo "  (none)"
    fi
}

# Verify installation
cmd_verify() {
    print_header
    echo "Installation Verification"
    echo "-------------------------"
    
    local all_ok=true
    
    # Check binary location
    echo "Checking binary location..."
    if [[ -x "$DEFAULT_BIN_DIR/spark-monitor" ]]; then
        echo "  ✓ Binary found at $DEFAULT_BIN_DIR/spark-monitor"
    else
        echo "  ✗ Binary not found at $DEFAULT_BIN_DIR/spark-monitor"
        all_ok=false
    fi
    
    # Check config directory
    echo "Checking configuration directory..."
    if [[ -d "$DEFAULT_CONFIG_DIR" ]]; then
        echo "  ✓ Config directory exists at $DEFAULT_CONFIG_DIR"
    else
        echo "  ✗ Config directory not found at $DEFAULT_CONFIG_DIR"
        all_ok=false
    fi
    
    # Check required files
    echo "Checking required files..."
    local required_files=("docker-compose.yml" "prometheus.yml" "custom-dcgm-counters.csv")
    for file in "${required_files[@]}"; do
        if [[ -f "$DEFAULT_CONFIG_DIR/$file" ]]; then
            echo "  ✓ $file"
        else
            echo "  ✗ $file (missing)"
            all_ok=false
        fi
    done
    
    # Check dependencies
    echo "Checking dependencies..."
    if command -v docker &> /dev/null; then
        echo "  ✓ Docker"
    else
        echo "  ✗ Docker (missing)"
        all_ok=false
    fi
    
    if command -v docker compose &> /dev/null; then
        echo "  ✓ Docker Compose"
    else
        echo "  ✗ Docker Compose (missing)"
        all_ok=false
    fi
    
    if command -v curl &> /dev/null; then
        echo "  ✓ curl"
    else
        echo "  ✗ curl (missing)"
        all_ok=false
    fi
    
    # Check PATH
    echo "Checking PATH..."
    if [[ ":$PATH:" == *":$DEFAULT_BIN_DIR:"* ]]; then
        echo "  ✓ $DEFAULT_BIN_DIR is in PATH"
    else
        echo "  ⚠ $DEFAULT_BIN_DIR is not in PATH"
        echo "    Add to PATH by running: export PATH=\"\$PATH:$DEFAULT_BIN_DIR\""
        echo "    Or add to ~/.bashrc: echo 'export PATH=\"\$PATH:$DEFAULT_BIN_DIR\"' >> ~/.bashrc"
    fi
    
    if $all_ok; then
        print_success "All checks passed!"
        return 0
    else
        print_error "Some checks failed. Run 'spark-monitor install' to fix."
        return 1
    fi
}

# Install CLI and configs
cmd_install() {
    local force=false
    local config_dir="$DEFAULT_CONFIG_DIR"
    local bin_dir="$DEFAULT_BIN_DIR"
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)
                force=true
                shift
                ;;
            --config-dir)
                config_dir="$2"
                shift 2
                ;;
            --bin-dir)
                bin_dir="$2"
                shift 2
                ;;
            *)
                print_error "Unknown option: $1"
                return 1
                ;;
        esac
    done
    
    print_header
    echo "Installation"
    echo "------------"
    
    # Check if already installed
    if [[ -f "$bin_dir/spark-monitor" ]]; then
        if [[ "$force" != "true" ]]; then
            print_warning "Already installed at $bin_dir/spark-monitor"
            print_info "Use --force to overwrite"
            return 1
        else
            print_info "Overwriting existing installation"
            rm -f "$bin_dir/spark-monitor"
        fi
    fi
    
    # Check if config already exists
    if [[ -d "$config_dir" ]] && [[ -f "$config_dir/docker-compose.yml" ]]; then
        if [[ "$force" != "true" ]]; then
            print_warning "Config directory already exists at $config_dir"
            print_info "Use --force to overwrite"
            return 1
        else
            print_info "Overwriting existing configuration"
            rm -rf "$config_dir"
        fi
    fi
    
    # Create directories
    print_info "Creating directories..."
    mkdir -p "$bin_dir"
    mkdir -p "$config_dir"
    
    # Copy binary
    print_info "Installing binary..."
    local source_dir=$(get_project_dir)
    cp "$source_dir/spark-monitor" "$bin_dir/spark-monitor"
    chmod +x "$bin_dir/spark-monitor"
    
    # Copy configuration files
    print_info "Copying configuration files..."
    cp "$source_dir/docker-compose.yml" "$config_dir/"
    cp "$source_dir/prometheus.yml" "$config_dir/"
    cp "$source_dir/custom-dcgm-counters.csv" "$config_dir/"
    
    # Copy directories
    if [[ -d "$source_dir/grafana" ]]; then
        cp -r "$source_dir/grafana" "$config_dir/"
    fi
    
    if [[ -d "$source_dir/prometheus" ]]; then
        cp -r "$source_dir/prometheus" "$config_dir/"
    fi
    
    if [[ -d "$source_dir/exporters" ]]; then
        cp -r "$source_dir/exporters" "$config_dir/"
    fi
    
    if [[ -d "$source_dir/scripts" ]]; then
        cp -r "$source_dir/scripts" "$config_dir/"
    fi
    
    # Write version file
    if [[ -f "$PROJECT_DIR/VERSION" ]]; then
        cp "$PROJECT_DIR/VERSION" "$config_dir/"
    else
        echo "1.0.0" > "$config_dir/VERSION"
    fi
    
    # Update docker-compose.yml to use absolute paths
    print_info "Updating configuration paths..."
    sed -i "s|\.\/prometheus\.yml|$config_dir\/prometheus.yml|g" "$config_dir/docker-compose.yml"
    sed -i "s|./custom-dcgm-counters.csv|$config_dir/custom-dcgm-counters.csv|g" "$config_dir/docker-compose.yml"
    
    # Check if ~/.local/bin is in PATH
    if [[ ":$PATH:" != *":$bin_dir:"* ]]; then
        print_warning "$bin_dir is not in your PATH"
        echo ""
        print_info "To add it, run:"
        echo "  export PATH=\"\$PATH:$bin_dir\""
        echo ""
        print_info "Or add to ~/.bashrc:"
        echo "  echo 'export PATH=\"\$PATH:$bin_dir\"' >> ~/.bashrc"
        echo "  source ~/.bashrc"
    fi
    
    print_success "Installation complete!"
    echo ""
    print_info "To verify, run: spark-monitor verify"
    print_info "To start services, run: spark-monitor start"
}

# Uninstall CLI and configs
cmd_uninstall() {
    local mode="cli-only"  # cli-only, configs, full
    local force=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --cli-only)
                mode="cli-only"
                shift
                ;;
            --configs)
                mode="configs"
                shift
                ;;
            --full)
                mode="full"
                shift
                ;;
            --force)
                force=true
                shift
                ;;
            *)
                print_error "Unknown option: $1"
                return 1
                ;;
        esac
    done
    
    # Interactive mode
    if [[ "$force" != "true" ]]; then
        print_header
        echo "Uninstall Options:"
        echo "1) CLI only (remove binary, keep configs and Docker)"
        echo "2) CLI + configs (remove binary and config files)"
        echo "3) Full removal (CLI, configs, and Docker)"
        echo ""
        
        read -p "Enter choice [1-3]: " choice
        
        case "$choice" in
            1) mode="cli-only" ;;
            2) mode="configs" ;;
            3) mode="full" ;;
            *) 
                print_error "Invalid choice"
                return 1
                ;;
        esac
    fi
    
    print_header
    echo "Uninstall Process"
    echo "-----------------"
    echo "Mode: $mode"
    
    # Confirmation
    if [[ "$force" != "true" ]]; then
        read -p "Are you sure you want to uninstall? [y/N]: " confirm
        if [[ "$confirm" != "y" ]] && [[ "$confirm" != "Y" ]]; then
            print_info "Uninstall cancelled"
            return 0
        fi
    fi
    
    case "$mode" in
        cli-only)
            print_info "Removing CLI binary..."
            if [[ -f "$DEFAULT_BIN_DIR/spark-monitor" ]]; then
                rm -f "$DEFAULT_BIN_DIR/spark-monitor"
                print_success "Binary removed"
            else
                print_warning "Binary not found at $DEFAULT_BIN_DIR"
            fi
            echo ""
            print_info "Configuration preserved at $DEFAULT_CONFIG_DIR"
            echo "Docker containers remain running"
            ;;
            
        configs)
            print_info "Removing CLI binary..."
            if [[ -f "$DEFAULT_BIN_DIR/spark-monitor" ]]; then
                rm -f "$DEFAULT_BIN_DIR/spark-monitor"
                print_success "Binary removed"
            else
                print_warning "Binary not found at $DEFAULT_BIN_DIR"
            fi
            
            print_info "Removing configuration directory..."
            if [[ -d "$DEFAULT_CONFIG_DIR" ]]; then
                rm -rf "$DEFAULT_CONFIG_DIR"
                print_success "Configuration removed"
            else
                print_warning "Config directory not found at $DEFAULT_CONFIG_DIR"
            fi
            
            echo ""
            print_info "Docker containers remain running"
            ;;
            
        full)
            print_info "Stopping Docker containers..."
            local old_cwd=$(pwd)
            if [[ -f "$DEFAULT_CONFIG_DIR/docker-compose.yml" ]]; then
                cd "$DEFAULT_CONFIG_DIR"
                docker compose down || true
                cd "$old_cwd"
            fi
            
            print_info "Removing CLI binary..."
            if [[ -f "$DEFAULT_BIN_DIR/spark-monitor" ]]; then
                rm -f "$DEFAULT_BIN_DIR/spark-monitor"
                print_success "Binary removed"
            else
                print_warning "Binary not found at $DEFAULT_BIN_DIR"
            fi
            
            print_info "Removing configuration directory..."
            if [[ -d "$DEFAULT_CONFIG_DIR" ]]; then
                rm -rf "$DEFAULT_CONFIG_DIR"
                print_success "Configuration removed"
            else
                print_warning "Config directory not found at $DEFAULT_CONFIG_DIR"
            fi
            
            print_info "Cleaning up Docker volumes..."
            if [[ -f "$DEFAULT_CONFIG_DIR/docker-compose.yml" ]]; then
                cd "$DEFAULT_CONFIG_DIR"
                docker compose down -v || true
                cd "$old_cwd"
            fi
            
            print_success "Full uninstall complete"
            ;;
    esac
}

# Upgrade to latest version
cmd_upgrade() {
    local skip_backup=false
    local force=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --skip-backup)
                skip_backup=true
                shift
                ;;
            --force)
                force=true
                shift
                ;;
            *)
                print_error "Unknown option: $1"
                return 1
                ;;
        esac
    done
    
    print_header
    echo "Upgrade Process"
    echo "---------------"
    
    # Check if installed
    if [[ ! -f "$DEFAULT_BIN_DIR/spark-monitor" ]]; then
        print_error "Not installed. Run 'spark-monitor install' first."
        return 1
    fi
    
    if [[ ! -d "$DEFAULT_CONFIG_DIR" ]]; then
        print_error "Configuration directory not found. Run 'spark-monitor install' first."
        return 1
    fi
    
    # Check for new version (mock for now - would check GitHub releases)
    print_info "Checking for updates..."
    
    local current_version="1.0.0"
    if [[ -f "$VERSION_FILE" ]]; then
        current_version=$(cat "$VERSION_FILE")
    fi
    
    # For now, use current directory's VERSION file as source
    local latest_version="1.0.0"
    if [[ -f "$PROJECT_DIR/VERSION" ]]; then
        latest_version=$(cat "$PROJECT_DIR/VERSION")
    fi
    
    if [[ "$current_version" == "$latest_version" ]]; then
        print_info "Already at latest version ($current_version)"
        return 0
    fi
    
    print_info "Found new version: $latest_version"
    
    # Backup
    if [[ "$skip_backup" != "true" ]]; then
        print_info "Creating backup..."
        local backup_dir="$DEFAULT_CONFIG_DIR/backup_$(date +%Y%m%d_%H%M%S)"
        cp -r "$DEFAULT_CONFIG_DIR" "$backup_dir"
        print_success "Backup created at $backup_dir"
    fi
    
    # Update binary
    print_info "Updating binary..."
    local source_dir=$(get_project_dir)
    cp "$source_dir/spark-monitor" "$DEFAULT_BIN_DIR/spark-monitor"
    chmod +x "$DEFAULT_BIN_DIR/spark-monitor"
    print_success "Binary updated"
    
    # Update configs
    print_info "Updating configuration files..."
    cp "$source_dir/docker-compose.yml" "$DEFAULT_CONFIG_DIR/"
    cp "$source_dir/prometheus.yml" "$DEFAULT_CONFIG_DIR/"
    cp "$source_dir/custom-dcgm-counters.csv" "$DEFAULT_CONFIG_DIR/"
    
    # Update docker-compose.yml paths
    sed -i "s|\.\/prometheus\.yml|$DEFAULT_CONFIG_DIR\/prometheus.yml|g" "$DEFAULT_CONFIG_DIR/docker-compose.yml"
    sed -i "s|\.\/custom-dcgm-counters\.csv|$DEFAULT_CONFIG_DIR\/custom-dcgm-counters.csv|g" "$DEFAULT_CONFIG_DIR/docker-compose.yml"
    
    # Update version file
    if [[ -f "$source_dir/VERSION" ]]; then
        cp "$source_dir/VERSION" "$VERSION_FILE"
    else
        echo "$latest_version" > "$VERSION_FILE"
    fi
    
    # Copy new directories
    if [[ -d "$source_dir/grafana" ]]; then
        cp -r "$source_dir/grafana" "$DEFAULT_CONFIG_DIR/" 2>/dev/null || true
    fi
    
    if [[ -d "$source_dir/prometheus" ]]; then
        cp -r "$source_dir/prometheus" "$DEFAULT_CONFIG_DIR/" 2>/dev/null || true
    fi
    
    if [[ -d "$source_dir/exporters" ]]; then
        cp -r "$source_dir/exporters" "$DEFAULT_CONFIG_DIR/" 2>/dev/null || true
    fi
    
    if [[ -d "$PROJECT_DIR/scripts" ]]; then
        cp -r "$PROJECT_DIR/scripts" "$DEFAULT_CONFIG_DIR/" 2>/dev/null || true
    fi
    
    print_success "Upgrade complete!"
    echo ""
    print_info "Current version: $latest_version"
    print_info "To verify, run: spark-monitor verify"
}

# Show real-time metrics with category filtering
cmd_monitor() {
    local category="all"
    local interval=5
    local pos_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -i|--interval)
                interval="$2"
                shift 2
                ;;
            -h|--help)
                echo "Usage: spark-monitor monitor [category] [-i interval]"
                echo
                echo "Show real-time metrics with category filtering"
                echo
                echo "Arguments:"
                echo "  category    Metric category: system, gpu, vllm, or all (default: all)"
                echo "  -i, --interval    Refresh interval in seconds (default: 5, min: 1, max: 60)"
                echo "  -h, --help        Show this help message"
                echo
                echo "Examples:"
                echo "  spark-monitor monitor           # All metrics, 5s refresh"
                echo "  spark-monitor monitor system    # System metrics only"
                echo "  spark-monitor monitor gpu       # GPU metrics only"
    echo "  spark-monitor monitor vllm      # vLLM metrics only"
    echo "  spark-monitor monitor -i 10     # 10s refresh"
    echo "  spark-monitor monitor vllm -i 3 # vLLM with 3s refresh"
    echo
                echo "vLLM Metrics include:"
                echo "  - Generated Tokens / Prompt Tokens (cumulative counts)"
                echo "  - Waiting Requests / Running Requests (scheduler state)"
                echo "  - Generation TPS / Prompt TPS (tokens per second)"
                echo "  - Generation TPS max / Prompt TPS max (peak values, only update when non-zero)"
                echo "  - Idle Time (HH:MM:SS, shown when pending=running=0)"
                echo
                return 0
                ;;
            *)
                pos_args+=("$1")
                shift
                ;;
        esac
    done

    if [[ ${#pos_args[@]} -gt 0 ]]; then
        category="${pos_args[0]}"
    fi

    if [[ ! "$interval" =~ ^[0-9]+$ ]] || [[ "$interval" -lt 1 ]] || [[ "$interval" -gt 60 ]]; then
        print_error "Interval must be a number between 1 and 60"
        return 1
    fi

    case "$category" in
        system|gpu|vllm|all)
            ;;
        *)
            print_error "Invalid category: $category"
            echo "Valid categories: system, gpu, vllm, all"
            return 1
            ;;
    esac

    echo -e "${GREEN}=== Real-time Metrics Monitor ===${NC}"
    echo "Category: $category | Refresh: ${interval}s"
    echo "Press Ctrl+C to exit"
    echo "-------------------------------"
    echo

    trap 'echo; print_success "Monitoring stopped"; exit 0' INT
    trap 'print_error "Error during execution"; exit 1' ERR

    local prev_gen_tokens=""
    local prev_prompt_tokens=""
    local max_gen_tps=0.00
    local max_prompt_tps=0.00
    local idle_seconds=0
    local last_busy_time
    last_busy_time=$(date +%s)
    local is_idle=false

    while true; do
        printf "\033[2J\033[H"
        
        local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
        echo -e "${GREEN}=== Spark Monitor Real-time Metrics ===${NC}"
        echo "Timestamp: $timestamp"
        echo "-------------------------------"
        echo

        case "$category" in
            system|all)
                echo -e "${YELLOW}[SYSTEM]${NC}"
                local cpu_result
                cpu_result=$(query_prometheus '100 - avg by(instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100')
                if [ $? -eq 0 ] && [ -n "$cpu_result" ]; then
                    local cpu_value
                    cpu_value=$(echo "$cpu_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                    if [[ "$cpu_value" != "N/A" ]] && [[ "$cpu_value" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                        printf "  CPU Usage: %.2f%%\n" "$cpu_value"
                    else
                        echo "  CPU Usage: N/A (invalid data)"
                    fi
                else
                    echo "  CPU Usage: N/A (query failed)"
                fi
                local mem_result
                mem_result=$(query_prometheus '(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100')
                if [ $? -eq 0 ] && [ -n "$mem_result" ]; then
                    local mem_value
                    mem_value=$(echo "$mem_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                    if [[ "$mem_value" != "N/A" ]] && [[ "$mem_value" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                        printf "  Memory Usage: %.2f%%\n" "$mem_value"
                    else
                        echo "  Memory Usage: N/A (invalid data)"
                    fi
                else
                    echo "  Memory Usage: N/A (query failed)"
                fi
                echo
                ;;
        esac

        case "$category" in
            gpu|all)
                echo -e "${YELLOW}[GPU]${NC}"
                local gpu_util_result gpu_temp_result gpu_power_result
                gpu_util_result=$(query_prometheus 'DCGM_FI_DEV_GPU_UTIL')
                gpu_temp_result=$(query_prometheus 'DCGM_FI_DEV_GPU_TEMP')
                gpu_power_result=$(query_prometheus 'DCGM_FI_DEV_POWER_USAGE')
                
                local gpu_util gpu_temp gpu_power
                gpu_util="N/A"
                gpu_temp="N/A"
                gpu_power="N/A"
                
                if [ $? -eq 0 ] && [ -n "$gpu_util_result" ]; then
                    gpu_util=$(echo "$gpu_util_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$gpu_temp_result" ]; then
                    gpu_temp=$(echo "$gpu_temp_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$gpu_power_result" ]; then
                    gpu_power=$(echo "$gpu_power_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                
                if [[ "$gpu_util" != "N/A" ]] && [[ "$gpu_util" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    printf "  GPU Utilization: %s%%\n" "$gpu_util"
                else
                    echo "  GPU Utilization: N/A"
                fi
                if [[ "$gpu_temp" != "N/A" ]] && [[ "$gpu_temp" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    printf "  GPU Temperature: %s°C\n" "$gpu_temp"
                else
                    echo "  GPU Temperature: N/A"
                fi
                if [[ "$gpu_power" != "N/A" ]] && [[ "$gpu_power" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    printf "  GPU Power Usage: %s W\n" "$gpu_power"
                else
                    echo "  GPU Power Usage: N/A"
                fi
                echo
                ;;
        esac

        case "$category" in
            vllm|all)
                echo -e "${YELLOW}[vLLM]${NC}"
                local gen_tokens_result prompt_tokens_result pending_result running_result model_name_result
                gen_tokens_result=$(query_prometheus 'vllm:generation_tokens_total')
                prompt_tokens_result=$(query_prometheus 'vllm:prompt_tokens_total')
                pending_result=$(query_prometheus 'vllm:num_requests_waiting')
                running_result=$(query_prometheus 'vllm:num_requests_running')
                model_name_result=$(query_prometheus 'vllm:num_requests_running')
                
                local gen_tokens prompt_tokens pending running model_name
                gen_tokens="N/A"
                prompt_tokens="N/A"
                pending="N/A"
                running="N/A"
                model_name="N/A"
                
                if [ -n "$gen_tokens_result" ]; then
                    gen_tokens=$(echo "$gen_tokens_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$prompt_tokens_result" ]; then
                    prompt_tokens=$(echo "$prompt_tokens_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$pending_result" ]; then
                    pending=$(echo "$pending_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$running_result" ]; then
                    running=$(echo "$running_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$model_name_result" ]; then
                    model_name=$(echo "$model_name_result" | jq -r '.data.result[0].metric.model_name // "N/A"' 2>/dev/null)
                fi
                
                # 显示模型名
                if [[ "$model_name" != "N/A" ]]; then
                    echo -e "  Model: ${GREEN}$model_name${NC}"
                else
                    echo "  Model: N/A"
                fi
                
                # 检查是否有效数字
                if [[ "$gen_tokens" != "N/A" ]] && [[ "$gen_tokens" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    printf "  Generated Tokens: %s\n" "$gen_tokens"
                else
                    echo "  Generated Tokens: N/A"
                fi
                if [[ "$prompt_tokens" != "N/A" ]] && [[ "$prompt_tokens" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    printf "  Prompt Tokens: %s\n" "$prompt_tokens"
                else
                    echo "  Prompt Tokens: N/A"
                fi
                if [[ "$pending" != "N/A" ]] && [[ "$pending" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    printf "  Waiting Requests: %s\n" "$pending"
                else
                    echo "  Waiting Requests: N/A"
                fi
                if [[ "$running" != "N/A" ]] && [[ "$running" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    printf "  Running Requests: %s\n" "$running"
                else
                    echo "  Running Requests: N/A"
                fi
                
                local gen_tps prompt_tps
                gen_tps="N/A"
                prompt_tps="N/A"
                
                # 安全地计算TPS（每秒令牌数）
                if [[ "$gen_tokens" != "N/A" ]] && [[ "$gen_tokens" =~ ^[0-9]+\.?[0-9]*$ ]] && \
                   [[ "$prev_gen_tokens" != "N/A" ]] && [[ "$prev_gen_tokens" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    local gen_diff
                    gen_diff=$(awk "BEGIN {print $gen_tokens - $prev_gen_tokens}")
                    if [[ "$gen_diff" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                        gen_tps=$(awk "BEGIN {printf \"%.2f\", $gen_diff / $interval}")
                    fi
                fi
                if [[ "$prompt_tokens" != "N/A" ]] && [[ "$prompt_tokens" =~ ^[0-9]+\.?[0-9]*$ ]] && \
                   [[ "$prev_prompt_tokens" != "N/A" ]] && [[ "$prev_prompt_tokens" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    local prompt_diff
                    prompt_diff=$(awk "BEGIN {print $prompt_tokens - $prev_prompt_tokens}")
                    if [[ "$prompt_diff" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                        prompt_tps=$(awk "BEGIN {printf \"%.2f\", $prompt_diff / $interval}")
                    fi
                fi
                
                # 检查vLLM是否Idle（pending=0且running=0，都是有效数字0）
                is_idle=false
                if [[ "$pending" != "N/A" ]] && [[ "$running" != "N/A" ]] && \
                   [[ "$pending" =~ ^[0-9]+$ ]] && [[ "$running" =~ ^[0-9]+$ ]] && \
                   [[ "$pending" -eq 0 ]] && [[ "$running" -eq 0 ]]; then
                    is_idle=true
                fi
                
                if [[ "$gen_tps" != "N/A" ]] && [[ "$gen_tps" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    printf "  Generation TPS: %s tokens/s\n" "$gen_tps"
                    # 只在值非零时更新max (避免在N/A或0时更新)
                    local gen_tps_nonzero
                    gen_tps_nonzero=$(awk -v val="$gen_tps" 'BEGIN {print (val > 0) ? "1" : "0"}')
                    if [[ "$gen_tps_nonzero" == "1" ]]; then
                        max_gen_tps=$(awk -v cur="$gen_tps" -v max="$max_gen_tps" 'BEGIN {print (cur > max) ? cur : max}')
                    fi
                else
                    echo "  Generation TPS: N/A"
                fi
                if [[ "$prompt_tps" != "N/A" ]] && [[ "$prompt_tps" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    printf "  Prompt TPS: %s tokens/s\n" "$prompt_tps"
                    # 只在值非零时更新max (避免在N/A或0时更新)
                    local prompt_tps_nonzero
                    prompt_tps_nonzero=$(awk -v val="$prompt_tps" 'BEGIN {print (val > 0) ? "1" : "0"}')
                    if [[ "$prompt_tps_nonzero" == "1" ]]; then
                        max_prompt_tps=$(awk -v cur="$prompt_tps" -v max="$max_prompt_tps" 'BEGIN {print (cur > max) ? cur : max}')
                    fi
                else
                    echo "  Prompt TPS: N/A"
                fi
                
                # 显示max TPS (只在有有效非零值时显示)
                local max_gen_nonzero
                max_gen_nonzero=$(awk -v val="$max_gen_tps" 'BEGIN {print (val > 0) ? "1" : "0"}')
                if [[ "$max_gen_nonzero" == "1" ]]; then
                    printf "  Generation TPS (max): %.2f tokens/s\n" "$max_gen_tps"
                fi
                local max_prompt_nonzero
                max_prompt_nonzero=$(awk -v val="$max_prompt_tps" 'BEGIN {print (val > 0) ? "1" : "0"}')
                if [[ "$max_prompt_nonzero" == "1" ]]; then
                    printf "  Prompt TPS (max): %.2f tokens/s\n" "$max_prompt_tps"
                fi
                
                # 计算Idle时长
                if $is_idle; then
                    local current_time
                    current_time=$(date +%s)
                    idle_seconds=$((current_time - last_busy_time))
                else
                    last_busy_time=$(date +%s)
                    idle_seconds=0
                fi
                
                if [[ "$idle_seconds" -gt 0 ]]; then
                    local idle_hours
                    idle_hours=$((idle_seconds / 3600))
                    local idle_mins
                    idle_mins=$(((idle_seconds % 3600) / 60))
                    local idle_secs
                    idle_secs=$((idle_seconds % 60))
                    printf "  Idle Time: %02d:%02d:%02d\n" "$idle_hours" "$idle_mins" "$idle_secs"
                fi
                echo
                
                # 只在值是有效数字时更新历史值
                if [[ "$gen_tokens" != "N/A" ]] && [[ "$gen_tokens" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    prev_gen_tokens=$gen_tokens
                fi
                if [[ "$prompt_tokens" != "N/A" ]] && [[ "$prompt_tokens" =~ ^[0-9]+\.?[0-9]*$ ]]; then
                    prev_prompt_tokens=$prompt_tokens
                fi
                ;;
        esac

        sleep "$interval"
    done
}

