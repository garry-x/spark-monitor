    cmd_health() {
        check_project_dir
        
        print_header
        print_info "Performing health checks..."
        
        # Check if services are accessible
        local services=(
            "prometheus:9090"
            "grafana:3000"
            "node_exporter:9100"
            "gpu_exporter:9400"
        )
        
        all_healthy=true
        
        # Check Docker services (accessible from localhost)
        for service in "${services[@]}"; do
            IFS=':' read -r name port <<< "$service"
            # Accept 200 (OK), 302 (redirect, e.g., Prometheus), 401 (unauthorized), 403 (forbidden)
            if curl -s -o /dev/null -w "%{http_code}" "http://localhost:${port}/" 2>/dev/null | grep -q "200\|302\|401\|403"; then
                print_success "$name (:$port) is accessible"
            else
                print_error "$name (:$port) is not accessible"
                all_healthy=false
            fi
        done
        
        # Special check for vLLM service (running on host)
        print_info "Checking vLLM service (host service)..."
        if curl -s -o /dev/null -w "%{http_code}" "http://localhost:8000/" 2>/dev/null | grep -q "200\|302\|401\|403\|404"; then
            print_success "vLLM (:8000) is accessible"
        else
            print_warning "vLLM (:8000) is not accessible (may not be running)"
            # Don't mark as unhealthy since vLLM is optional
        fi
        
        # Check vLLM metrics endpoint specifically
        print_info "Checking vLLM metrics endpoint..."
        if curl -s -o /dev/null -w "%{http_code}" "http://localhost:8000/metrics" 2>/dev/null | grep -q "200\|302\|401\|403"; then
            print_success "vLLM metrics endpoint is accessible"
        else
            print_warning "vLLM metrics endpoint is not accessible"
        fi
        
        if $all_healthy; then
            print_success "All core services are healthy!"
        else
            print_error "Some core services are not responding correctly"
            exit 1
        fi
    }

# Show listening ports and processes
cmd_ports() {
    local proto="both"
    local filter_port=""
    local sort_by="port"
    local use_sudo=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            check)
                shift
                cmd_ports_check "$@"
                return $?
                ;;
            -t|--tcp)
                proto="tcp"
                shift
                ;;
            -u|--udp)
                proto="udp"
                shift
                ;;
            -p|--port)
                filter_port="$2"
                shift 2
                ;;
            -s|--sort)
                sort_by="$2"
                shift 2
                ;;
            -S|--sudo)
                use_sudo=true
                shift
                ;;
            -h|--help)
                echo "Usage: spark-monitor ports [options]"
                echo "       spark-monitor ports check <port> [proto]"
                echo
                echo "Show host listening ports and corresponding processes"
                echo
                echo "Options:"
                echo "  check PORT [proto]  Check if a port is in use (proto: tcp/udp/both)"
                echo "  -t, --tcp           Show TCP only"
                echo "  -u, --udp           Show UDP only"
                echo "  -p, --port PORT     Filter by port number"
                echo "  -s, --sort BY       Sort by: port (default), pid, protocol"
                echo "  -S, --sudo          Use sudo for full process info"
                echo "  -h, --help          Show this help message"
                echo
                echo "Examples:"
                echo "  spark-monitor ports             # All listening ports"
                echo "  spark-monitor ports -t          # TCP only"
                echo "  spark-monitor ports -S          # With sudo (shows all PIDs)"
                echo "  spark-monitor ports -p 9090     # Filter by port 9090"
                echo "  spark-monitor ports -s pid      # Sort by PID"
                echo "  spark-monitor ports check 9090  # Check port 9090"
                echo
                return 0
                ;;
            *)
                print_error "Unknown option: $1"
                return 1
                ;;
        esac
    done
    
    if ! command -v ss &> /dev/null; then
        print_error "ss command not found. Please install iproute2."
        return 1
    fi
    
    local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    echo -e "${GREEN}=== Host Listening Ports ===${NC}"
    echo "Timestamp: $timestamp"
    echo "-------------------------------"
    printf "%-6s %-22s %-8s %s\n" "PROTO" "LOCAL ADDRESS" "PID" "PROCESS"
    echo "-------------------------------"
    
    local tmpfile=$(mktemp)
    
    # Use sudo if requested or if already running as root
    local ss_cmd="ss -tulnp"
    if [[ "$use_sudo" == true ]]; then
        if [[ $EUID -ne 0 ]]; then
            if command -v sudo &> /dev/null && sudo -n true 2>/dev/null; then
                ss_cmd="sudo ss -tulnp"
            else
                # sudo not available or requires password, fall back to regular ss
                if ! command -v sudo &> /dev/null; then
                    print_warning "sudo not found, running without elevated privileges"
                else
                    print_warning "sudo requires password, running without elevated privileges"
                    print_info "Hint: Add 'your_user ALL=(ALL) NOPASSWD: /usr/sbin/ss' to /etc/sudoers"
                fi
            fi
        fi
    elif command -v sudo &> /dev/null && sudo -n true 2>/dev/null; then
        ss_cmd="sudo ss -tulnp"
    fi
    
    # Always use -tulnp to get consistent column layout
    $ss_cmd 2>/dev/null | tail -n +2 | awk -v proto_filter="$proto" -v port_filter="$filter_port" '
    {
        p = $1
        local_addr = $5
        pid = "-"
        pname = "-"
        for (i = 7; i <= NF; i++) {
            if ($i ~ /users:/) {
                rest = ""
                for (j = i; j <= NF; j++) rest = rest " " $j
                if (match(rest, /pid=([0-9]+)/, arr)) pid = arr[1]
                if (match(rest, /users:\(\("([^"]+)"/, arr)) pname = arr[1]
                break
            }
        }
        n = split(local_addr, parts, ":")
        port = parts[n]
        gsub(/%.*/, "", port)
        if (port ~ /^[0-9]+$/) {
            if ((proto_filter == "both" || proto_filter == p) && (port_filter == "" || port == port_filter)) {
                printf "%-6s %-22s %-8s %s\n", p, local_addr, pid, pname
            }
        }
    }' > "$tmpfile"
    
    case "$sort_by" in
        pid)
            sort -k3 -n "$tmpfile"
            ;;
        protocol)
            sort -k1 "$tmpfile"
            ;;
        *)
            sort -t: -k2 -n "$tmpfile"
            ;;
    esac
    
    local count=$(wc -l < "$tmpfile")
    rm -f "$tmpfile"
    
    echo "-------------------------------"
    echo "Total: $count listening ports"
}

# Check if a specific port is in use
cmd_ports_check() {
    if [[ $# -lt 1 ]]; then
        print_error "Usage: spark-monitor ports check <port> [proto]"
        echo
        echo "Check if a specific port is in use"
        echo
        echo "Arguments:"
        echo "  port    Port number to check"
        echo "  proto   Protocol: tcp, udp, or both (default: tcp)"
        echo
        echo "Examples:"
        echo "  spark-monitor ports check 9090"
        echo "  spark-monitor ports check 9090 udp"
        echo
        return 1
    fi
    
    local port="$1"
    local proto="${2:-tcp}"
    
    if ! [[ "$port" =~ ^[0-9]+$ ]]; then
        print_error "Invalid port number: $port"
        return 1
    fi
    
    if [[ "$proto" != "tcp" && "$proto" != "udp" && "$proto" != "both" ]]; then
        print_error "Invalid protocol: $proto (must be tcp, udp, or both)"
        return 1
    fi
    
    local ss_prefix=""
    if command -v sudo &> /dev/null && sudo -n true 2>/dev/null; then
        ss_prefix="sudo"
    fi
    
    echo -e "${GREEN}=== Port Check ===${NC}"
    echo "Checking port: $port ($proto)"
    echo "-------------------------------"
    
    local found=$($ss_prefix ss -tulnp 2>/dev/null | tail -n +2 | awk -v target_port="$port" -v proto_filter="$proto" '
    {
        p = $1
        local_addr = $5
        pid = "-"
        pname = "-"
        for (i = 7; i <= NF; i++) {
            if ($i ~ /users:/) {
                rest = ""
                for (j = i; j <= NF; j++) rest = rest " " $j
                if (match(rest, /pid=([0-9]+)/, arr)) pid = arr[1]
                if (match(rest, /users:\(\("([^"]+)"/, arr)) pname = arr[1]
                break
            }
        }
        n = split(local_addr, parts, ":")
        port = parts[n]
        gsub(/%.*/, "", port)
        if (port == target_port && (proto_filter == "both" || proto_filter == p)) {
            printf "  %-6s %-22s PID: %-8s Process: %s\n", p, local_addr, pid, pname
        }
    }')
    
    if [[ -n "$found" ]]; then
        echo "$found"
        echo "-------------------------------"
        print_warning "Port $port ($proto) is IN USE"
    else
        echo "  No processes listening on this port"
        echo "-------------------------------"
        print_success "Port $port ($proto) is AVAILABLE"
    fi
}

