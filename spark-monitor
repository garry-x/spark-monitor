#!/bin/bash

# Spark Monitor CLI - Management tool for the DGXSpark monitoring system
# Usage: spark-monitor [command] [options]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$SCRIPT_DIR"
COMPOSE_FILE="$PROJECT_DIR/docker-compose.yml"

# Configuration directory for installed mode
DEFAULT_CONFIG_DIR="$HOME/.config/spark-monitor"
DEFAULT_BIN_DIR="$HOME/.local/bin"
VERSION_FILE="$DEFAULT_CONFIG_DIR/VERSION"

# Get project directory (either current dir or config dir based on installation state)
get_project_dir() {
    if is_installed_mode; then
        echo "$DEFAULT_CONFIG_DIR"
    else
        echo "$PROJECT_DIR"
    fi
}

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Helper functions
print_header() {
    echo -e "${GREEN}=== Spark Monitor Management Tool ===${NC}"
    echo
}

print_success() {
    echo -e "${GREEN}[SUCCESS] $1${NC}"
}

print_error() {
    echo -e "${RED}[ERROR] $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}[WARNING] $1${NC}"
}

print_info() {
    echo -e "${YELLOW}[INFO] $1${NC}"
}

# Check if running in installed mode
is_installed_mode() {
    # 如果配置目录存在且脚本不在项目目录中，则是安装模式
    if [[ -d "$DEFAULT_CONFIG_DIR" ]] && [[ ! -f "$PROJECT_DIR/docker-compose.yml" ]]; then
        return 0
    fi
    
    # 如果配置目录存在且脚本路径与项目目录不同，也是安装模式
    if [[ -d "$DEFAULT_CONFIG_DIR" ]] && [[ "$SCRIPT_DIR" != "$PROJECT_DIR" ]]; then
        return 0
    fi
    
    return 1
}

# Get config directory (installed or project)
get_config_dir() {
    if is_installed_mode; then
        echo "$DEFAULT_CONFIG_DIR"
    else
        echo "$PROJECT_DIR"
    fi
}

# Get binary directory (installed or project)
get_binary_dir() {
    if is_installed_mode; then
        echo "$DEFAULT_BIN_DIR"
    else
        echo "$SCRIPT_DIR"
    fi
}

# Check if docker compose is available
check_docker_compose() {
    if ! command -v docker compose &> /dev/null; then
        print_error "docker compose not found. Please install Docker Compose."
        exit 1
    fi
}

# Check if we're in the project or config directory
check_project_dir() {
    local config_dir=$(get_config_dir)
    
    if [ ! -f "$config_dir/docker-compose.yml" ]; then
        print_error "docker-compose.yml not found. Please run this script from the project directory or ensure it's installed."
        exit 1
    fi
}

# Execute docker compose command in the correct directory
docker_compose_exec() {
    local config_dir=$(get_config_dir)
    local old_cwd=$(pwd)
    
    cd "$config_dir" || {
        print_error "Cannot change to config directory: $config_dir"
        return 1
    }
    
    docker compose "$@"
    local result=$?
    
    cd "$old_cwd" || true
    return $result
}

# Show status of all services
cmd_status() {
    check_docker_compose
    check_project_dir
    
    print_header
    echo "Service Status:"
    echo "---------------"
    docker_compose_exec ps
    echo
    
    # Show container details
    echo "Detailed Container Information:"
    echo "-------------------------------"
    docker_compose_exec ps --format "table {{.Name}}\t{{.State}}\t{{.Ports}}"
    echo
}

# Start all services
cmd_start() {
    check_docker_compose
    check_project_dir
    
    print_header
    print_info "Starting Spark Monitor services..."
    docker_compose_exec up -d
    
    # Wait a moment for services to start
    sleep 3
    
    print_success "Services started successfully!"
    echo
    echo "Access URLs:"
    echo "  Prometheus: http://localhost:9090"
    echo "  Grafana: http://localhost:3000 (admin/admin)"
    echo
    echo "Use 'spark-monitor logs' to view logs"
    echo "Use 'spark-monitor status' to check service status"
}

# Stop all services
cmd_stop() {
    check_docker_compose
    check_project_dir
    
    print_header
    
    if [ "$#" -eq 0 ]; then
        # No args: stop all compose services defined in docker-compose.yml
        print_info "Stopping Spark Monitor services..."
        docker_compose_exec down
    else
        # Stop specific services by name
        local services=("$@")
        print_info "Stopping specified services: ${services[*]}"
        docker compose stop "${services[@]}"
    fi
    
    print_success "Services stopped successfully!"
}

# Restart all services
cmd_restart() {
    check_docker_compose
    check_project_dir
    
    print_header
    print_info "Restarting Spark Monitor services..."
    docker_compose_exec restart
    print_success "Services restarted successfully!"
}

# View logs
cmd_logs() {
    check_docker_compose
    check_project_dir
    
    if [ "$#" -eq 0 ]; then
        # Show all logs
        docker_compose_exec logs -f
    else
        # Show logs for specific service
        docker_compose_exec logs -f "$@"
    fi
}

# Query Prometheus API
query_prometheus() {
    local query="$1"
    local encoded_query=$(urlencode "$query")
    curl -s -f --max-time 10 "http://localhost:9090/api/v1/query?query=${encoded_query}" 2>/dev/null
}

urlencode() {
    local string="$1"
    local encoded=""
    local pos c
    for ((pos=0; pos<${#string}; pos++)); do
        c="${string:$pos:1}"
        case "$c" in
            [-_.~a-zA-Z0-9]) encoded+="$c" ;;
            *) printf -v c '%%%02x' "'$c" && encoded+="$c" ;;
        esac
    done
    echo "$encoded"
}

