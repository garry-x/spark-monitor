#!/bin/bash

# Spark Monitor CLI - Management tool for the DGXSpark monitoring system
# Usage: spark-monitor-cli [command] [options]

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$SCRIPT_DIR"
COMPOSE_FILE="$PROJECT_DIR/docker-compose.yml"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Helper functions
print_header() {
    echo -e "${GREEN}=== Spark Monitor Management Tool ===${NC}"
    echo
}

print_success() {
    echo -e "${GREEN}[SUCCESS] $1${NC}"
}

print_error() {
    echo -e "${RED}[ERROR] $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}[WARNING] $1${NC}"
}

print_info() {
    echo -e "${YELLOW}[INFO] $1${NC}"
}

# Check if docker compose is available
check_docker_compose() {
    if ! command -v docker compose &> /dev/null; then
        print_error "docker compose not found. Please install Docker Compose."
        exit 1
    fi
}

# Check if we're in the project directory
check_project_dir() {
    if [ ! -f "$COMPOSE_FILE" ]; then
        print_error "docker-compose.yml not found. Please run this script from the project directory."
        exit 1
    fi
}

# Show status of all services
cmd_status() {
    check_docker_compose
    check_project_dir
    
    print_header
    echo "Service Status:"
    echo "---------------"
    docker compose ps
    echo
    
    # Show container details
    echo "Detailed Container Information:"
    echo "-------------------------------"
    docker compose ps --format "table {{.Name}}\t{{.State}}\t{{.Ports}}"
    echo
}

# Start all services
cmd_start() {
    check_docker_compose
    check_project_dir
    
    print_header
    print_info "Starting Spark Monitor services..."
    docker compose up -d
    
    # Wait a moment for services to start
    sleep 3
    
    print_success "Services started successfully!"
    echo
    echo "Access URLs:"
    echo "  Prometheus: http://localhost:9090"
    echo "  Grafana: http://localhost:3000 (admin/admin)"
    echo
    echo "Use 'spark-monitor-cli logs' to view logs"
    echo "Use 'spark-monitor-cli status' to check service status"
}

# Stop all services
cmd_stop() {
    check_docker_compose
    check_project_dir
    
    print_header
    print_info "Stopping Spark Monitor services..."
    docker compose down
    print_success "Services stopped successfully!"
}

# Restart all services
cmd_restart() {
    check_docker_compose
    check_project_dir
    
    print_header
    print_info "Restarting Spark Monitor services..."
    docker compose restart
    print_success "Services restarted successfully!"
}

# View logs
cmd_logs() {
    check_docker_compose
    check_project_dir
    
    if [ "$#" -eq 0 ]; then
        # Show all logs
        docker compose logs -f
    else
        # Show logs for specific service
        docker compose logs -f "$@"
    fi
}

# Query Prometheus API
query_prometheus() {
    local query="$1"
    local encoded_query=$(urlencode "$query")
    curl -s -f --max-time 10 "http://localhost:9090/api/v1/query?query=${encoded_query}" 2>/dev/null
}

urlencode() {
    local string="$1"
    local encoded=""
    local pos c
    for ((pos=0; pos<${#string}; pos++)); do
        c="${string:$pos:1}"
        case "$c" in
            [-_.~a-zA-Z0-9]) encoded+="$c" ;;
            *) printf -v c '%%%02x' "'$c" && encoded+="$c" ;;
        esac
    done
    echo "$encoded"
}

# Show general help
cmd_help() {
    print_header
    echo "Usage: spark-monitor-cli [command] [options]"
    echo
    echo "Commands:"
    echo "  status    Show status of all services"
    echo "  start     Start all services"
    echo "  stop      Stop all services"
    echo "  restart   Restart all services"
    echo "  logs      View logs (add service name for specific service logs)"
    echo "  health    Check health of all services"
    echo "  ports     Show listening ports and processes"
    echo "            ports check PORT [proto] - Check if port is in use"
    echo "  monitor   Show real-time metrics (system|gpu|vllm|all) [-i interval]"
    echo "  help      Show this help message"
    echo
    echo "Monitor Examples:"
    echo "  spark-monitor-cli monitor           # All metrics, 5s refresh"
    echo "  spark-monitor-cli monitor system    # System metrics only"
    echo "  spark-monitor-cli monitor gpu       # GPU metrics only"
    echo "  spark-monitor-cli monitor vllm      # vLLM metrics only"
    echo "  spark-monitor-cli monitor -i 10     # 10s refresh"
    echo "  spark-monitor-cli monitor vllm -i 3 # vLLM with 3s refresh"
    echo
}

# Show real-time metrics with category filtering
cmd_monitor() {
    local category="all"
    local interval=5
    local pos_args=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -i|--interval)
                interval="$2"
                shift 2
                ;;
            -h|--help)
                echo "Usage: spark-monitor-cli monitor [category] [-i interval]"
                echo
                echo "Show real-time metrics with category filtering"
                echo
                echo "Arguments:"
                echo "  category    Metric category: system, gpu, vllm, or all (default: all)"
                echo "  -i, --interval    Refresh interval in seconds (default: 5, min: 1, max: 60)"
                echo "  -h, --help        Show this help message"
                echo
                echo "Examples:"
                echo "  spark-monitor-cli monitor           # All metrics, 5s refresh"
                echo "  spark-monitor-cli monitor system    # System metrics only"
                echo "  spark-monitor-cli monitor gpu       # GPU metrics only"
                echo "  spark-monitor-cli monitor vllm      # vLLM metrics only"
                echo "  spark-monitor-cli monitor -i 10     # 10s refresh"
                echo "  spark-monitor-cli monitor vllm -i 3 # vLLM with 3s refresh"
                echo
                echo "vLLM Metrics include:"
                echo "  - Generated Tokens / Prompt Tokens (cumulative counts)"
                echo "  - Waiting Requests / Running Requests (scheduler state)"
                echo "  - Generation TPS / Prompt TPS (tokens per second)"
                echo
                return 0
                ;;
            *)
                pos_args+=("$1")
                shift
                ;;
        esac
    done

    if [[ ${#pos_args[@]} -gt 0 ]]; then
        category="${pos_args[0]}"
    fi

    if [[ ! "$interval" =~ ^[0-9]+$ ]] || [[ "$interval" -lt 1 ]] || [[ "$interval" -gt 60 ]]; then
        print_error "Interval must be a number between 1 and 60"
        return 1
    fi

    case "$category" in
        system|gpu|vllm|all)
            ;;
        *)
            print_error "Invalid category: $category"
            echo "Valid categories: system, gpu, vllm, all"
            return 1
            ;;
    esac

    echo -e "${GREEN}=== Real-time Metrics Monitor ===${NC}"
    echo "Category: $category | Refresh: ${interval}s"
    echo "Press Ctrl+C to exit"
    echo "-------------------------------"
    echo

    trap 'echo; print_success "Monitoring stopped"; exit 0' INT EXIT
    trap 'print_error "Error during execution"; exit 1' ERR

    local prev_gen_tokens=""

    while true; do
        printf "\033[2J\033[H"
        
        local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
        echo -e "${GREEN}=== Spark Monitor Real-time Metrics ===${NC}"
        echo "Timestamp: $timestamp"
        echo "-------------------------------"
        echo

        case "$category" in
            system|all)
                echo -e "${YELLOW}[SYSTEM]${NC}"
                local cpu_result
                cpu_result=$(query_prometheus '100 - avg by(instance) (irate(node_cpu_seconds_total{mode="idle"}[5m])) * 100')
                if [ $? -eq 0 ] && [ -n "$cpu_result" ]; then
                    local cpu_value
                    cpu_value=$(echo "$cpu_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                    printf "  CPU Usage: %.2f%%\n" "$cpu_value"
                else
                    echo "  CPU Usage: N/A (query failed)"
                fi
                local mem_result
                mem_result=$(query_prometheus '(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes) / node_memory_MemTotal_bytes * 100')
                if [ $? -eq 0 ] && [ -n "$mem_result" ]; then
                    local mem_value
                    mem_value=$(echo "$mem_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                    printf "  Memory Usage: %.2f%%\n" "$mem_value"
                else
                    echo "  Memory Usage: N/A (query failed)"
                fi
                echo
                ;;
        esac

        case "$category" in
            gpu|all)
                echo -e "${YELLOW}[GPU]${NC}"
                local gpu_util_result gpu_temp_result gpu_power_result
                gpu_util_result=$(query_prometheus 'DCGM_FI_DEV_GPU_UTIL')
                gpu_temp_result=$(query_prometheus 'DCGM_FI_DEV_GPU_TEMP')
                gpu_power_result=$(query_prometheus 'DCGM_FI_DEV_POWER_USAGE')
                
                local gpu_util gpu_temp gpu_power
                gpu_util="N/A"
                gpu_temp="N/A"
                gpu_power="N/A"
                
                if [ $? -eq 0 ] && [ -n "$gpu_util_result" ]; then
                    gpu_util=$(echo "$gpu_util_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$gpu_temp_result" ]; then
                    gpu_temp=$(echo "$gpu_temp_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$gpu_power_result" ]; then
                    gpu_power=$(echo "$gpu_power_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                
                printf "  GPU Utilization: %s%%\n" "$gpu_util"
                printf "  GPU Temperature: %s°C\n" "$gpu_temp"
                printf "  GPU Power Usage: %s W\n" "$gpu_power"
                echo
                ;;
        esac

        case "$category" in
            vllm|all)
                echo -e "${YELLOW}[vLLM]${NC}"
                local gen_tokens_result prompt_tokens_result pending_result running_result
                gen_tokens_result=$(query_prometheus 'vllm:generation_tokens_total')
                prompt_tokens_result=$(query_prometheus 'vllm:prompt_tokens_total')
                pending_result=$(query_prometheus 'vllm:num_requests_waiting')
                running_result=$(query_prometheus 'vllm:num_requests_running')
                
                local gen_tokens prompt_tokens pending running
                gen_tokens="N/A"
                prompt_tokens="N/A"
                pending="N/A"
                running="N/A"
                
                if [ -n "$gen_tokens_result" ]; then
                    gen_tokens=$(echo "$gen_tokens_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$prompt_tokens_result" ]; then
                    prompt_tokens=$(echo "$prompt_tokens_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$pending_result" ]; then
                    pending=$(echo "$pending_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                if [ -n "$running_result" ]; then
                    running=$(echo "$running_result" | jq -r '.data.result[0].value[1] // "N/A"' 2>/dev/null)
                fi
                
                 printf "  Generated Tokens: %s\n" "$gen_tokens"
                 printf "  Prompt Tokens: %s\n" "$prompt_tokens"
                 printf "  Waiting Requests: %s\n" "$pending"
                 printf "  Running Requests: %s\n" "$running"
                 
                 local gen_tps prompt_tps
                 gen_tps="N/A"
                 prompt_tps="N/A"
                 
                 if [ -n "$gen_tokens_result" ] && [ -n "$prev_gen_tokens" ]; then
                     local gen_diff=$((gen_tokens - prev_gen_tokens))
                     gen_tps=$(awk "BEGIN {printf \"%.2f\", $gen_diff / $interval}")
                 fi
                 if [ -n "$prompt_tokens_result" ] && [ -n "$prev_prompt_tokens" ]; then
                     local prompt_diff=$((prompt_tokens - prev_prompt_tokens))
                     prompt_tps=$(awk "BEGIN {printf \"%.2f\", $prompt_diff / $interval}")
                 fi
                 
                 printf "  Generation TPS: %s tokens/s\n" "$gen_tps"
                 printf "  Prompt TPS: %s tokens/s\n" "$prompt_tps"
                 echo
                 
                 prev_gen_tokens=$gen_tokens
                 prev_prompt_tokens=$prompt_tokens
                 ;;
        esac

        sleep "$interval"
    done
}

    # Health check endpoint verification
    cmd_health() {
        check_project_dir
        
        print_header
        print_info "Performing health checks..."
        
        # Check if services are accessible
        local services=(
            "prometheus:9090"
            "grafana:3000"
            "node_exporter:9100"
            "gpu_exporter:9400"
            "vllm:8000"
        )
        
        all_healthy=true
        
        for service in "${services[@]}"; do
            IFS=':' read -r name port <<< "$service"
            # Accept 200 (OK), 302 (redirect, e.g., Prometheus), 401 (unauthorized), 403 (forbidden)
            if curl -s -o /dev/null -w "%{http_code}" "http://localhost:${port}/" 2>/dev/null | grep -q "200\|302\|401\|403"; then
                print_success "$name (:$port) is accessible"
            else
                print_error "$name (:$port) is not accessible"
                all_healthy=false
            fi
        done
        
        if $all_healthy; then
            print_success "All services are healthy!"
        else
            print_error "Some services are not responding correctly"
            exit 1
        fi
    }

# Show listening ports and processes
cmd_ports() {
    local proto="both"
    local filter_port=""
    local sort_by="port"
    local use_sudo=false
    
    while [[ $# -gt 0 ]]; do
        case "$1" in
            check)
                shift
                cmd_ports_check "$@"
                return $?
                ;;
            -t|--tcp)
                proto="tcp"
                shift
                ;;
            -u|--udp)
                proto="udp"
                shift
                ;;
            -p|--port)
                filter_port="$2"
                shift 2
                ;;
            -s|--sort)
                sort_by="$2"
                shift 2
                ;;
            -S|--sudo)
                use_sudo=true
                shift
                ;;
            -h|--help)
                echo "Usage: spark-monitor-cli ports [options]"
                echo "       spark-monitor-cli ports check <port> [proto]"
                echo
                echo "Show host listening ports and corresponding processes"
                echo
                echo "Options:"
                echo "  check PORT [proto]  Check if a port is in use (proto: tcp/udp/both)"
                echo "  -t, --tcp           Show TCP only"
                echo "  -u, --udp           Show UDP only"
                echo "  -p, --port PORT     Filter by port number"
                echo "  -s, --sort BY       Sort by: port (default), pid, protocol"
                echo "  -S, --sudo          Use sudo for full process info"
                echo "  -h, --help          Show this help message"
                echo
                echo "Examples:"
                echo "  spark-monitor-cli ports             # All listening ports"
                echo "  spark-monitor-cli ports -t          # TCP only"
                echo "  spark-monitor-cli ports -S          # With sudo (shows all PIDs)"
                echo "  spark-monitor-cli ports -p 9090     # Filter by port 9090"
                echo "  spark-monitor-cli ports -s pid      # Sort by PID"
                echo "  spark-monitor-cli ports check 9090  # Check port 9090"
                echo
                return 0
                ;;
            *)
                print_error "Unknown option: $1"
                return 1
                ;;
        esac
    done
    
    if ! command -v ss &> /dev/null; then
        print_error "ss command not found. Please install iproute2."
        return 1
    fi
    
    local timestamp=$(date "+%Y-%m-%d %H:%M:%S")
    echo -e "${GREEN}=== Host Listening Ports ===${NC}"
    echo "Timestamp: $timestamp"
    echo "-------------------------------"
    printf "%-6s %-22s %-8s %s\n" "PROTO" "LOCAL ADDRESS" "PID" "PROCESS"
    echo "-------------------------------"
    
    local tmpfile=$(mktemp)
    
    # Use sudo if requested or if already running as root
    local ss_cmd="ss -tulnp"
    if [[ "$use_sudo" == true ]]; then
        if [[ $EUID -ne 0 ]]; then
            if command -v sudo &> /dev/null && sudo -n true 2>/dev/null; then
                ss_cmd="sudo ss -tulnp"
            else
                # sudo not available or requires password, fall back to regular ss
                if ! command -v sudo &> /dev/null; then
                    print_warning "sudo not found, running without elevated privileges"
                else
                    print_warning "sudo requires password, running without elevated privileges"
                    print_info "Hint: Add 'your_user ALL=(ALL) NOPASSWD: /usr/sbin/ss' to /etc/sudoers"
                fi
            fi
        fi
    elif command -v sudo &> /dev/null && sudo -n true 2>/dev/null; then
        ss_cmd="sudo ss -tulnp"
    fi
    
    # Always use -tulnp to get consistent column layout
    $ss_cmd 2>/dev/null | tail -n +2 | awk -v proto_filter="$proto" -v port_filter="$filter_port" '
    {
        p = $1
        local_addr = $5
        pid = "-"
        pname = "-"
        for (i = 7; i <= NF; i++) {
            if ($i ~ /users:/) {
                rest = ""
                for (j = i; j <= NF; j++) rest = rest " " $j
                if (match(rest, /pid=([0-9]+)/, arr)) pid = arr[1]
                if (match(rest, /users:\(\("([^"]+)"/, arr)) pname = arr[1]
                break
            }
        }
        n = split(local_addr, parts, ":")
        port = parts[n]
        gsub(/%.*/, "", port)
        if (port ~ /^[0-9]+$/) {
            if ((proto_filter == "both" || proto_filter == p) && (port_filter == "" || port == port_filter)) {
                printf "%-6s %-22s %-8s %s\n", p, local_addr, pid, pname
            }
        }
    }' > "$tmpfile"
    
    case "$sort_by" in
        pid)
            sort -k3 -n "$tmpfile"
            ;;
        protocol)
            sort -k1 "$tmpfile"
            ;;
        *)
            sort -t: -k2 -n "$tmpfile"
            ;;
    esac
    
    local count=$(wc -l < "$tmpfile")
    rm -f "$tmpfile"
    
    echo "-------------------------------"
    echo "Total: $count listening ports"
}

# Check if a specific port is in use
cmd_ports_check() {
    if [[ $# -lt 1 ]]; then
        print_error "Usage: spark-monitor-cli ports check <port> [proto]"
        echo
        echo "Check if a specific port is in use"
        echo
        echo "Arguments:"
        echo "  port    Port number to check"
        echo "  proto   Protocol: tcp, udp, or both (default: tcp)"
        echo
        echo "Examples:"
        echo "  spark-monitor-cli ports check 9090"
        echo "  spark-monitor-cli ports check 9090 udp"
        echo
        return 1
    fi
    
    local port="$1"
    local proto="${2:-tcp}"
    
    if ! [[ "$port" =~ ^[0-9]+$ ]]; then
        print_error "Invalid port number: $port"
        return 1
    fi
    
    if [[ "$proto" != "tcp" && "$proto" != "udp" && "$proto" != "both" ]]; then
        print_error "Invalid protocol: $proto (must be tcp, udp, or both)"
        return 1
    fi
    
    local ss_prefix=""
    if command -v sudo &> /dev/null && sudo -n true 2>/dev/null; then
        ss_prefix="sudo"
    fi
    
    echo -e "${GREEN}=== Port Check ===${NC}"
    echo "Checking port: $port ($proto)"
    echo "-------------------------------"
    
    local found=$($ss_prefix ss -tulnp 2>/dev/null | tail -n +2 | awk -v target_port="$port" -v proto_filter="$proto" '
    {
        p = $1
        local_addr = $5
        pid = "-"
        pname = "-"
        for (i = 7; i <= NF; i++) {
            if ($i ~ /users:/) {
                rest = ""
                for (j = i; j <= NF; j++) rest = rest " " $j
                if (match(rest, /pid=([0-9]+)/, arr)) pid = arr[1]
                if (match(rest, /users:\(\("([^"]+)"/, arr)) pname = arr[1]
                break
            }
        }
        n = split(local_addr, parts, ":")
        port = parts[n]
        gsub(/%.*/, "", port)
        if (port == target_port && (proto_filter == "both" || proto_filter == p)) {
            printf "  %-6s %-22s PID: %-8s Process: %s\n", p, local_addr, pid, pname
        }
    }')
    
    if [[ -n "$found" ]]; then
        echo "$found"
        echo "-------------------------------"
        print_warning "Port $port ($proto) is IN USE"
    else
        echo "  No processes listening on this port"
        echo "-------------------------------"
        print_success "Port $port ($proto) is AVAILABLE"
    fi
}

# Main script logic
case "$1" in
    status)
        cmd_status
        ;;
    start)
        cmd_start
        ;;
    stop)
        cmd_stop
        ;;
    restart)
        cmd_restart
        ;;
    logs)
        shift
        cmd_logs "$@"
        ;;
    health)
        cmd_health
        ;;
    ports)
        shift
        cmd_ports "$@"
        ;;
    monitor)
        shift
        cmd_monitor "$@"
        ;;
    help|*)
        cmd_help
        ;;
esac